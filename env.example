# Environment Variables for Hackathon Dashboard
# Copy this file to .env and fill in your actual values

# Google Calendar API Configuration (Frontend)
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google OAuth 2.0 Configuration (Backend)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:10000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# SMTP Configuration for Email Notifications
REACT_APP_SMTP_HOST=smtp.gmail.com
REACT_APP_SMTP_PORT=587
REACT_APP_SMTP_USER=your_email@gmail.com
REACT_APP_SMTP_PASS=your_app_password_here

# Server Configuration
SERVER_PORT=10000
NODE_ENV=development

# MongoDB Connection (Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/hackathon-dashboard?retryWrites=true&w=majority&appName=HackathonDashboard

# JWT Authentication (REQUIRED - generate a strong random secret for production)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=7d

# Backend Email / SMTP Configuration (Gmail with App Password)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
# Backend SMTP (recommended if not using Gmail defaults)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your_email@gmail.com

# SendGrid (recommended for hosted environments like Render)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM=your_verified_sendgrid_sender@example.com
# Note: For Gmail, you need to use an App Password, not your regular password
# Enable 2FA and generate an App Password in your Google Account settings
