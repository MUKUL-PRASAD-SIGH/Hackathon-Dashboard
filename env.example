# Environment Variables for Hackathon Dashboard
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=10000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/storybook

# JWT Authentication (REQUIRED - generate a strong random secret for production)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=7d

# Email / SMTP Configuration (Gmail with App Password)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Google Calendar API Configuration
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Note: For Gmail, you need to use an App Password, not your regular password
# Enable 2FA and generate an App Password in your Google Account settings
