# Environment Variables for Version 1.1.0 Features
# Copy this file to .env and fill in your actual values

# Google Calendar API Configuration (Frontend)
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google OAuth 2.0 Configuration (Backend)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:10000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# SMTP Configuration for Email Notifications
REACT_APP_SMTP_HOST=smtp.gmail.com
REACT_APP_SMTP_PORT=587
REACT_APP_SMTP_USER=your_email@gmail.com
REACT_APP_SMTP_PASS=your_app_password_here

# Note: For Gmail, you need to use an App Password, not your regular password
# Enable 2FA and generate an App Password in your Google Account settings
